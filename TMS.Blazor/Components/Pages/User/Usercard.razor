<div class="@($"bg-surface-container-lowest p-5 rounded-xl border-r-4 flex items-center justify-between group hover:shadow-md transition-shadow {User.AccentClass}")">
    <div class="flex items-center gap-4">
        <div class="@($"w-12 h-12 rounded-full flex items-center justify-center {User.AvatarClass}")">
            <span class="material-symbols-outlined">person</span>
        </div>
        <div>
            <p class="font-bold text-on-surface">@User.FullName</p>
            <p class="text-xs text-on-surface-variant">@User.SecondaryText</p>
        </div>
    </div>

    <button class="p-2 rounded-full text-error hover:bg-error-container/10 transition-colors"
            type="button"
            title="Delete user"
            @onclick="HandleDeleteAsync">
        <span class="material-symbols-outlined">delete</span>
    </button>
</div>
 
@code {
    [Parameter, EditorRequired]
    public UserCardModel User { get; set; } = default!;

    [Parameter]
    public EventCallback<int> OnDelete { get; set; }

    private Task HandleDeleteAsync() => OnDelete.InvokeAsync(User.Id);
}
